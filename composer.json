{
    "name": "krma-cl/kcfinder-laravel",
    "description": "Laravel integration for the maintained KCFinder continuation.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/filesystem": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "krma-cl/kcfinder": "^4.9"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5|^12.0"
    },
    "suggest": {
        "krma-cl/kcfinder-bootstrap5-theme": "Installs and mounts the official Bootstrap 5 theme without modifying the core package."
    },
    "autoload": {
        "psr-4": {
            "Krma\\KCFinder\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Krma\\KCFinder\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Krma\\KCFinder\\Laravel\\KCFinderServiceProvider"
            ],
            "aliases": {
                "KCFinder": "Krma\\KCFinder\\Laravel\\Facades\\KCFinder"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "check": [
            "@test",
            "@analyse"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
